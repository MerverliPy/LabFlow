{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "allowJs": true,
    "checkJs": true,
    "noEmit": true,
    "types": ["node"],
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "strict": false
  },
  "include": [
    "bin/**/*.mjs",
    "packages/**/*.mjs",
    "tools/**/*.mjs"
  ],
  "exclude": [
    "node_modules",
    "verification/runs"
  ]
}
