{
  "name": "labflow",
  "version": "0.1.0",
  "private": true,
  "description": "Claude Code-native orchestration toolkit with a verified terminal-first core.",
  "packageManager": "pnpm@10.0.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MerverliPy/LabFlow.git"
  },
  "homepage": "https://labflowdevelopment.calvinbrady8.workers.dev",
  "bugs": {
    "url": "https://github.com/MerverliPy/LabFlow/issues"
  },
  "engines": {
    "node": ">=20"
  },
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "validate:manifest": "node tools/validate-manifest.mjs",
    "generate:docs": "node tools/generate-docs.mjs",
    "check:shell": "bash scripts/check-shell.sh",
    "proof:verify": "node packages/proof-sdk/src/index.mjs verify",
    "ci": "pnpm validate:manifest && pnpm generate:docs && pnpm check:shell",
    "validate:cloudflare": "node tools/validate-cloudflare.mjs",
    "worker:dev": "wrangler dev",
    "worker:deploy": "wrangler deploy",
    "worker:tail": "wrangler tail",
    "worker:check": "node tools/validate-cloudflare.mjs"
  },
  "devDependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.1.0",
    "@types/node": "^22.10.0",
    "typescript": "^5.7.2",
    "wrangler": "^4.68.0"
  },
  "author": "LabFlowDevelopment"
}
