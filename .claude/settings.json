{
  "model": "sonnet",
  "effortLevel": "medium",
  "enabledPlugins": {
    "typescript-lsp@claude-plugins-official": true
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/filter-verify-output.py"
          }
        ]
      }
    ]
  }
}
